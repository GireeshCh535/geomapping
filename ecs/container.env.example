# =============================================================================
# ECS runtime env file — upload to S3 (UTF-8, KEY=VALUE per line, no export)
#   aws s3 cp container.env s3://<bucket>/geomapping/<env>.env
# Task definition environmentFiles must point to:
#   arn:aws:s3:::<bucket>/geomapping/<env>.env
# =============================================================================

# Database (RDS)
DJANGO_DB_HOST=layers-db.cjso82amml7c.ap-south-1.rds.amazonaws.com
DJANGO_DB_PORT=5432
DJANGO_DB_NAME=geo_mapping_db
DJANGO_DB_USER=postgres
DJANGO_DB_PASSWORD=
DJANGO_DB_SSLMODE=require

# Redis (ElastiCache — use rediss:// when encryption in transit is on)
REDIS_URL=rediss://<elasticache-endpoint>:6379/1

# Django
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=layers-staging.citylands.in,localhost

# Tiles / R2
PUBLIC_TILE_CDN_HOST=tiles.citylands.in
CLOUDFLARE_R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET_NAME=gis-portal-layers
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
USE_CLOUDFRONT=false
ENABLE_CLOUDFRONT_INVALIDATION=false

# App URLs
DEVELOPER_BACKEND_API_URL=https://be.1acre.in
API_KEY_DOMAIN_FALLBACK_HOST=prod-be-aws.1acre.in
TILE_SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/<account-id>/geomapping-tile-gen-queue
TILE_CALLBACK_BASE_URL=https://layers-staging.citylands.in/
TILE_PROXY_PUBLIC_BASE_URL=https://layers-staging.citylands.in
TILE_CALLBACK_SECRET=
TILE_DEBUG_PRINTS=false

# Gunicorn
WEB_CONCURRENCY=4
GUNICORN_TIMEOUT=60
