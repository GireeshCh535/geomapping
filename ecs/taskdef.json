{
  "family": "geomapping-web",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/<execution-role>",
  "taskRoleArn": "arn:aws:iam::<account-id>:role/<task-role>",
  "containerDefinitions": [
    {
      "name": "web",
      "image": "<account-id>.dkr.ecr.ap-south-1.amazonaws.com/<ecr-repo>:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environmentFiles": [
        {
          "value": "arn:aws:s3:::<bucket>/geomapping/<env>.env",
          "type": "s3"
        }
      ],
      "command": [
        "gunicorn",
        "geo_mapping.wsgi:application",
        "-c",
        "gunicorn_config.py"
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/geomapping-staging",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "web"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "python manage.py check || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 90
      }
    }
  ]
}
