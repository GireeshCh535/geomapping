# Local-only R2 details. Gitignored.
#
# Usage:
#   source .r2.env

# Cloudflare account ID (the hex string in your R2 endpoint host).
export R2_ACCOUNT_ID="5cffd3efb5504dd9789406854c5bab60"

# R2 bucket name (e.g. gis-portal-layers).
export R2_BUCKET="gis-portal-layers"

# R2 API token (S3-compatible Access Key / Secret pair from the R2 dashboard).
export R2_ACCESS_KEY_ID="6df209d58f44c6b0f037a24b7f7215b0"
export R2_SECRET_ACCESS_KEY="b6bd718dcfd3d8c70605cb754f3995c7dfd278e32aa781112443dec61c0b3548"

# R2 ignores region but SigV4 signing needs a value; "auto" is safe.
export R2_REGION="auto"

# Derived endpoint. Do not edit unless Cloudflare changes the host scheme.
export R2_ENDPOINT_URL="https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com"
